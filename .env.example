# Development:
#   VITE_API_URL is NOT needed — Vite proxy handles routing.
#   Proxy target defaults to http://localhost:8080.
#   Override at start time: VITE_API_URL=http://178.156.230.233:8081 pnpm dev
#
# Production build:
#   Set VITE_API_URL to the backend origin for direct requests.
#   VITE_API_URL=https://api.example.com

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
